# ============================================================
# Server Configuration
# ============================================================

# Server listening address (default: 0.0.0.0 for all interfaces)
LEANSERVER_HOST=0.0.0.0

# Server port (default: 8000)
LEANSERVER_PORT=8000

# ============================================================
# Logging Configuration
# ============================================================

# Log directory path (default: ./logs)
LEANSERVER_LOG_DIR=./logs

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LEANSERVER_LOG_LEVEL=INFO

# ============================================================
# Workspace Configuration
# ============================================================

# Lean workspace directory (leave empty to use default)
LEANSERVER_WORKSPACE=

# ============================================================
# REPL Configuration
# ============================================================

# Maximum number of REPL processes (leave empty to use CPU count)
LEANSERVER_MAX_REPLS=

# Memory limit per REPL process in GB (default: 8)
LEANSERVER_REPL_MEMORY_LIMIT_GB=8

# Memory usage ratio threshold (default: 0.95)
LEANSERVER_REPL_MEMORY_RATIO=0.95

# Strictly enforce memory limits (default: false)
# In Linux, one can add per REPL memory limits directly when spawning the lake env repl process
LEANSERVER_HARD_ENFORCE_MEMORY_LIMIT=false

# ============================================================
# Ray Serve Configuration
# ============================================================

# Number of Ray Serve replicas for HTTP handling (default: 4)
# Each replica handles concurrent HTTP requests
LEANSERVER_SERVE_NUM_REPLICAS=4

# CPU resources per replica (default: 1.0)
# Supports fractional values: 0.5 = half core, 0.25 = quarter core
# Lower values allow more replicas to share CPU resources
LEANSERVER_REPLICA_CPU_PER_TASK=1.0

# Global worker pool size for REPL processing (default: 64)
# These workers execute the actual verification tasks
LEANSERVER_WORKER_POOL_SIZE=64

# CPU resources per worker (default: 1.0)
# Supports fractional values: 0.5 = half core
# Max workers = available_cpus / this value
LEANSERVER_WORKER_CPU_PER_TASK=1.0

# ============================================================
# REPL Cache Configuration
# ============================================================

# Enable REPL environment caching (default: true)
# Caching significantly speeds up verification for codes with same imports
LEANSERVER_ENABLE_REPL_CACHE=true

# Max cached environments per worker (default: 3)
# 3 is optimal with intelligent routing (cache-aware task distribution)
LEANSERVER_MAX_CACHED_ENVS=3

# Max reuse count per cached environment before refresh (default: 12)
# Prevents memory leaks by refreshing environments after N reuses
LEANSERVER_MAX_ENV_REUSE_COUNT=12

# Min tasks per worker before overflow (default: 5)
# Actual threshold = max(avg_load, this value)
# Lower = more parallelism, Higher = more cache hits
LEANSERVER_OVERFLOW_THRESHOLD=5
